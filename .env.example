# Copy to .env.local and fill in real values.
# .env.local is gitignored; never commit real secrets.

# -------- Database --------
# Neon, Vercel Postgres, or any Postgres connection string.
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# -------- Auth.js --------
# Session signing secret. Generate with: openssl rand -base64 32
AUTH_SECRET=""

# Resend API key for magic-link emails. Get one at https://resend.com
AUTH_RESEND_KEY=""

# Verified sender address, e.g. "InventoryDex <noreply@yourdomain.com>"
AUTH_EMAIL_FROM=""

# -------- Access control --------
# Comma-separated list of ADMIN emails. These accounts are always allowed to
# sign in and are automatically promoted to the ADMIN role on first sign-in.
# They can then manage other users via the /admin UI.
# All other users must be explicitly invited via the admin UI (Invite table).
ALLOWED_EMAILS="you@example.com"

# -------- Cron --------
# Shared secret required by POST /api/cron/refresh-prices.
# Add this as a GitHub Actions secret (repo Settings → Secrets → Actions → CRON_SECRET).
# The workflow in .github/workflows/refresh-prices.yml sends it in the x-cron-secret header.
# Generate with: openssl rand -hex 32
CRON_SECRET=""

# -------- Pokémon TCG API (optional but strongly recommended for beta) --------
# Raises rate limits from 100 req/min to 1 000 req/min.
# Without this key the price-refresh cron may approach Vercel's 60-second
# function timeout for inventories with more than ~100 unique cards.
# Get one at https://dev.pokemontcg.io/
POKEMONTCG_API_KEY=""

# -------- Pricing thresholds (optional) --------
# % change in market price over 7 days that triggers a badge. Default: 5
# PRICE_CHANGE_THRESHOLD_PCT=5
# % gap between list price and market price that flags a row. Default: 15
# LIST_PRICE_THRESHOLD_PCT=15
