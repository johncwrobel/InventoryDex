// Prisma schema for InventoryDex
// See CLAUDE.md for the overall data model rationale.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------- Auth.js models ----------
// These four models are required by @auth/prisma-adapter.
// See https://authjs.dev/getting-started/adapters/prisma

model User {
  id             String                @id @default(cuid())
  name           String?
  email          String                @unique
  emailVerified  DateTime?
  image          String?
  createdAt      DateTime              @default(now())
  role           Role                  @default(USER)
  accounts       Account[]
  sessions       Session[]
  inventory      InventoryItem[]
  sealedInventory SealedInventoryItem[]
  sentInvites    Invite[]              @relation("SentInvites")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ---------- Domain models ----------

// Canonical Pokémon card data mirrored from pokemontcg.io.
// Shared across all users so we only fetch/refresh each unique card once.
model Card {
  id             String          @id // pokemontcg.io id, e.g. "sv1-25"
  name           String
  setId          String
  setName        String
  number         String // collector number within set
  rarity         String?
  imageSmall     String?
  imageLarge     String?
  tcgplayerUrl   String?
  lastFetchedAt  DateTime        @default(now())
  prices         PricePoint[]
  inventoryItems InventoryItem[]

  @@index([name])
  @@index([setId, number])
}

// A single vendor's copy (or stack of copies) of a card.
// Multiple rows per card allowed — different condition / finish / purchase lots.
model InventoryItem {
  id             String    @id @default(cuid())
  userId         String
  cardId         String
  quantity       Int       @default(1)
  condition      Condition @default(NEAR_MINT)
  finish         Finish    @default(NORMAL)
  language       String    @default("EN")
  purchasePrice  Decimal   @db.Decimal(10, 2) // what the vendor paid
  purchasedAt    DateTime?
  listPrice      Decimal?  @db.Decimal(10, 2) // vendor's asking price
  notes          String?
  // Graded card fields — isGraded=false means a raw card (condition used normally).
  // When isGraded=true, condition is stored as NEAR_MINT but hidden from the UI;
  // gradingCompany and grade are the authoritative condition descriptor.
  isGraded       Boolean   @default(false)
  gradingCompany String?   // e.g. "PSA", "BGS", "CGC"
  grade          String?   // e.g. "10", "9.5", "Pristine"
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  card Card @relation(fields: [cardId], references: [id])

  @@index([userId])
  @@index([userId, cardId])
}

// Historical market-price snapshots per (card, finish).
// Enables "recent change" computations over arbitrary windows (24h, 7d, 30d).
model PricePoint {
  id         String   @id @default(cuid())
  cardId     String
  finish     Finish
  market     Decimal? @db.Decimal(10, 2)
  low        Decimal? @db.Decimal(10, 2)
  mid        Decimal? @db.Decimal(10, 2)
  high       Decimal? @db.Decimal(10, 2)
  capturedAt DateTime @default(now())

  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@index([cardId, finish, capturedAt])
}

// Invite table: admin adds email addresses; signIn callback checks this
// table when the email isn't in the ALLOWED_EMAILS admin list.
model Invite {
  id         String    @id @default(cuid())
  email      String    @unique
  invitedBy  String    // userId of the admin who created the invite
  createdAt  DateTime  @default(now())
  acceptedAt DateTime? // null = pending, non-null = consumed at first sign-in

  inviter User @relation("SentInvites", fields: [invitedBy], references: [id])

  @@index([email])
}

// Shared sealed product catalog — one entry per distinct product, shared across
// all users. Mirrors the Card model pattern. Users' inventory lots link here.
model SealedProduct {
  id           String            @id @default(cuid())
  setId        String?           // pokemontcg.io set ID (e.g. "sv8"); null for accessories
  setName      String?           // denormalized from pokemontcg.io for display
  productType  SealedProductType
  name         String            // e.g. "Surging Sparks Booster Box"
  tcgplayerUrl String?           // used by cron for price scraping + UI deep link
  imageUrl     String?
  createdAt    DateTime          @default(now())

  prices         SealedPricePoint[]
  inventoryItems SealedInventoryItem[]

  @@index([name])
  @@index([setId, productType])
}

// Historical market-price snapshots per SealedProduct, populated by the cron
// job via TCGPlayer HTML scraping. Never mutate — always INSERT a new row.
model SealedPricePoint {
  id              String   @id @default(cuid())
  sealedProductId String
  market          Decimal? @db.Decimal(10, 2)
  low             Decimal? @db.Decimal(10, 2)
  high            Decimal? @db.Decimal(10, 2)
  capturedAt      DateTime @default(now())

  product SealedProduct @relation(fields: [sealedProductId], references: [id], onDelete: Cascade)

  @@index([sealedProductId, capturedAt])
}

// A single user's lot of a sealed product. Multiple rows per SealedProduct
// are allowed (different purchase lots, quantities, etc.).
model SealedInventoryItem {
  id              String        @id @default(cuid())
  userId          String
  sealedProductId String
  // Inventory fields
  quantity        Int           @default(1)
  isSealed        Boolean       @default(true)
  purchasePrice   Decimal       @db.Decimal(10, 2)
  purchasedAt     DateTime?
  listPrice       Decimal?      @db.Decimal(10, 2)
  notes           String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  user    User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  product SealedProduct @relation(fields: [sealedProductId], references: [id])

  @@index([userId])
  @@index([userId, sealedProductId])
}

enum Role {
  ADMIN
  USER
}

enum Condition {
  MINT
  NEAR_MINT
  LIGHTLY_PLAYED
  MODERATELY_PLAYED
  HEAVILY_PLAYED
  DAMAGED
}

enum Finish {
  NORMAL
  HOLO
  REVERSE_HOLO
  FIRST_ED_HOLO
}

enum SealedProductType {
  BOOSTER_PACK
  BOOSTER_BUNDLE
  BOOSTER_BOX
  ELITE_TRAINER_BOX
  SUPER_PREMIUM_COLLECTION
  SPECIAL_COLLECTION
  THEME_DECK
  TIN
  OTHER
}
